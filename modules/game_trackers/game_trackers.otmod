Module
  name: game_trackers
  description: Contains all trackers
  reloadable: false
  author: gabp
  sandboxed: false
  autoload: true

  scripts: [classes/kill_tracker, classes/imbuement_tracker, classes/quest_tracker, game_trackers]
  load-later: true
  @onLoad: GameTrackersController:init()
  @onUnload: GameTrackersController:terminate()
